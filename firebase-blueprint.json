{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the platform",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "super_admin"] },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["uid", "email", "role"]
    },
    "Anime": {
      "title": "Anime",
      "description": "An anime series or movie",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "genres": { "type": "array", "items": { "type": "string" } },
        "studio": { "type": "string" },
        "type": { "type": "string", "enum": ["Series", "Movie"] },
        "releaseDate": { "type": "string" },
        "status": { "type": "string", "enum": ["Ongoing", "Completed", "Upcoming"] },
        "posterImage": { "type": "string" },
        "bannerImage": { "type": "string" },
        "trailer": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["id", "title", "type"]
    },
    "Episode": {
      "title": "Episode",
      "description": "An episode of an anime",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "animeId": { "type": "string" },
        "number": { "type": "number" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "thumbnail": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["id", "animeId", "number"]
    },
    "Source": {
      "title": "Source",
      "description": "A video source for an episode or movie",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "animeId": { "type": "string" },
        "episodeId": { "type": "string" },
        "type": { "type": "string", "enum": ["youtube", "hls", "mp4", "direct"] },
        "url": { "type": "string" },
        "label": { "type": "string" },
        "isPrimary": { "type": "boolean" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "animeId", "type", "url"]
    },
    "UserAction": {
      "title": "User Action",
      "description": "Watchlist, favorites, etc.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "animeId": { "type": "string" },
        "type": { "type": "string", "enum": ["watchlist", "favorite"] },
        "createdAt": { "type": "number" }
      },
      "required": ["userId", "animeId", "type"]
    },
    "History": {
      "title": "History",
      "description": "User watch progress",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "animeId": { "type": "string" },
        "episodeId": { "type": "string" },
        "progress": { "type": "number" },
        "duration": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["userId", "animeId", "progress"]
    }
  },
  "firestore": {
    "users": {
      "schema": "User",
      "description": "User profiles and roles"
    },
    "anime": {
      "schema": "Anime",
      "description": "Anime catalog"
    },
    "anime/{animeId}/episodes": {
      "schema": "Episode",
      "description": "Episodes for an anime"
    },
    "anime/{animeId}/episodes/{episodeId}/sources": {
      "schema": "Source",
      "description": "Sources for an episode (or root anime for movie)"
    },
    "anime/{animeId}/sources": {
      "schema": "Source",
      "description": "Sources for a movie"
    },
    "user_actions": {
      "schema": "UserAction",
      "description": "Watchlist and favorites."
    },
    "history": {
      "schema": "History",
      "description": "User watch history."
    }
  }
}
