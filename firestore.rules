rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && request.auth.token.email == 'ottus2023@gmail.com'; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256 &&
             data.role in ['user', 'super_admin'];
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(incoming()) && 
                    ((request.auth.token.email == 'ottus2023@gmail.com' && incoming().role == 'super_admin') || 
                     (request.auth.token.email != 'ottus2023@gmail.com' && incoming().role == 'user'));
      allow update: if (isOwner(userId) && isValidUser(incoming()) && incoming().role == existing().role) || isAdmin();
      allow delete: if isAdmin();
    }

    match /anime/{animeId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(animeId);
      allow update: if isAdmin();
      allow delete: if isAdmin();
      
      match /episodes/{episodeId} {
        allow read: if true;
        allow create: if isAdmin() && isValidId(episodeId);
        allow update: if isAdmin();
        allow delete: if isAdmin();
        
        match /sources/{sourceId} {
          allow read: if true;
          allow create: if isAdmin() && isValidId(sourceId);
          allow update: if isAdmin();
          allow delete: if isAdmin();
        }
      }
      
      match /sources/{sourceId} {
        allow read: if true;
        allow create: if isAdmin() && isValidId(sourceId);
        allow update: if isAdmin();
        allow delete: if isAdmin();
      }
    }

    match /user_actions/{actionId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && existing().userId == request.auth.uid && incoming().userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /history/{historyId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && existing().userId == request.auth.uid && incoming().userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
